# CareTrack AI — Environment Configuration
# Copy this file to .env and fill in values before running
# NEVER commit .env with real credentials to source control

# --- PostgreSQL ---
POSTGRES_USER=caretrack
POSTGRES_PASSWORD=caretrack_change_me_in_prod
POSTGRES_DB=caretrack_db

# --- Backend ---
DATABASE_URL=postgresql://caretrack:caretrack_change_me_in_prod@localhost:5432/caretrack_db
DEBUG=false

# --- Frontend ---
REACT_APP_API_URL=http://localhost:8000/api/v1

# --- Optional: LLM Integration ---
# Set USE_LLM=true and provide an API key to enable AI-powered summaries
USE_LLM=false
# ANTHROPIC_API_KEY=sk-ant-...   # For Claude integration

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# --- DISCLAIMER ---
# This is a demonstration system.
# It is NOT a certified medical device.
# Use SYNTHETIC DATA ONLY. Do not input real PHI.
